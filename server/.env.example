# Copy this file to .env and fill in your actual values
# Never commit .env to version control — it is in .gitignore
# Get your Gemini API key from: https://aistudio.google.com
# Get your MongoDB URI from: https://cloud.mongodb.com

# MongoDB Connection
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
# Create a cluster at: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/skillmaster-dev

# JWT Secret for token signing
# Must be at least 32 characters for cryptographic security
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-random-32-character-jwt-secret-here

# Gemini AI API Key
# Get from: https://aistudio.google.com
# Create an API key in your Google AI Studio account
GEMINI_API_KEY=your-gemini-api-key-here

# Server Port
# Default: 5000
PORT=5000
